# ============================================
# JOB BOT - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# Browser Use API Key (required)
# Get from: https://browseruse.com
BROWSER_USE_API_KEY=your_browser_use_api_key_here

# Also you will need an api key for your llm of choice to build resumes and for the bots. I use DeepSeek

# ============================================
# EMAIL REPORTING (Gmail App Password)
# ============================================
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECIPIENT=your_recipient@example.com

# ============================================
# MICROSOFT GRAPH API (for Greenhouse auto-code)
# Get client ID from: https://portal.azure.com
# ============================================
MS_CLIENT_ID=your_client_id_here
MS_SCOPES=Mail.Read,User.Read
MS_AUTHORITY=https://login.microsoftonline.com/consumers
MS_EMAIL=your_outlook_email@outlook.com

# ============================================
# PERSONAL INFO (for form filling)
# ============================================
FULL_NAME=Your Name Here
PHONE_NUMBER=1234567890

# ============================================
# PATHS (optional - defaults to project relative)
# ============================================
# AIHAWK_DIR=/path/to/your/AIHawk
